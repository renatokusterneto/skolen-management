# Google Sheets
# ID da planilha principal (encontrado na URL do Google Sheets)
GOOGLE_SHEETS_ID=your_spreadsheet_id

# Caminho para o arquivo de credenciais da Service Account do Google
GOOGLE_SERVICE_ACCOUNT_FILE=./google-service-account.json

# Cloudinary
# Encontre em: cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Instagram / Meta (meta-mcp)
# Gere em: developers.facebook.com/tools/explorer
# Permissões necessárias: instagram_basic, instagram_content_publish,
#   instagram_manage_comments, instagram_manage_insights,
#   pages_show_list, pages_read_engagement
INSTAGRAM_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_USER_ID=your_instagram_business_user_id
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
